# ── API mode ──────────────────────────────────────────────────────────────────
# Set to "true" to connect to the real backend.
# Leave "false" (or unset) to use in-memory demo data.
VITE_USE_API=false

# URL of the running backend (only matters when VITE_USE_API=true)
VITE_API_URL=http://localhost:4000/api/v1
