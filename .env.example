# ── Frontend API base URL ─────────────────────────────────────────────────────
# In development you normally DO NOT need to set this: the Vite dev server proxies
# "/api" to the backend at http://localhost:3001 (see vite.config.js), so the app
# talks to a same-origin "/api" and avoids CORS entirely.
#
# Only set VITE_API_URL when the frontend and backend are served from different
# origins (e.g. a deployed build). It must point at the backend's "/api" root:
#
#   VITE_API_URL=https://your-backend.example.com/api
#
# Leave it unset (commented out) to use the dev proxy default of "/api".
# VITE_API_URL=/api

# ── Patient portal invites (Gmail SMTP — free) ────────────────────────────────
# Gmail address that sends invite emails + an App Password (Google Account →
# Security → 2-Step Verification → App passwords). Leave blank to disable invites.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Public URL of the app, linked in invite emails
PORTAL_URL=http://localhost:3000
