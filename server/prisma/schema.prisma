// HealthVault Prisma Schema — v2
// Multi-tenant hospital architecture
// PostgreSQL + Prisma ORM

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Gender {
  Male
  Female
  Other
}

// Role assigned to a Credential (login generated by Admin)
enum CredentialRole {
  DOCTOR
  RECEPTIONIST
}

// Per-profile access level granted to a Credential
enum Permission {
  VIEW
  READ_WRITE
}

// Status of a write-access upgrade request
enum RequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum AppointmentStatus {
  scheduled
  completed
  cancelled
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum AuditAction {
  // ── Auth ──────────────────────────────────────────────────────────────────
  ADMIN_LOGIN
  ADMIN_LOGOUT
  CREDENTIAL_LOGIN
  CREDENTIAL_LOGOUT
  SESSION_LOCKED

  // ── Credential management ─────────────────────────────────────────────────
  CREDENTIAL_CREATED
  CREDENTIAL_UPDATED
  CREDENTIAL_REVOKED
  CREDENTIAL_REACTIVATED

  // ── Permission management ─────────────────────────────────────────────────
  PERMISSION_GRANTED
  PERMISSION_REVOKED
  PERMISSION_REQUEST_SENT
  PERMISSION_REQUEST_APPROVED
  PERMISSION_REQUEST_DENIED

  // ── Patient ───────────────────────────────────────────────────────────────
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_VIEWED

  // ── Visit ─────────────────────────────────────────────────────────────────
  VISIT_CREATED
  VISIT_UPDATED
  VISIT_VIEWED

  // ── Appointment ───────────────────────────────────────────────────────────
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  APPOINTMENT_CANCELLED
  APPOINTMENT_COMPLETED

  // ── AI ────────────────────────────────────────────────────────────────────
  AI_SUMMARY_GENERATED

  // ── Subscription & billing ────────────────────────────────────────────────
  SUBSCRIPTION_UPGRADED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_RENEWED

  // ── Profile ───────────────────────────────────────────────────────────────
  DOCTOR_PROFILE_UPDATED
}

// ─── Models ──────────────────────────────────────────────────────────────────

// Each hospital is a fully isolated tenant.
// No data crosses hospital boundaries at the DB level.
model Hospital {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins         Admin[]
  credentials    Credential[]
  doctorProfiles DoctorProfile[]
  patients       Patient[]
  appointments   Appointment[]
  auditLogs      AuditLog[]
}

// Hospital administrator — full access to the hospital's data.
// Manages credentials, permissions, and views audit logs.
model Admin {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  hospitalId   String
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  hospital         Hospital            @relation(fields: [hospitalId], references: [id])
  createdCreds     Credential[]        @relation("CredentialCreatedBy")
  grantedAccesses  ProfileAccess[]     @relation("AccessGrantedBy")
  resolvedRequests PermissionRequest[] @relation("RequestResolvedBy")
  auditLogs        AuditLog[]          @relation("AuditByAdmin")
}

// Login account generated by Admin for a doctor or receptionist.
// A credential can be granted access to one or more DoctorProfiles via ProfileAccess.
// isActive: false = credential is revoked and cannot log in.
model Credential {
  id           String         @id @default(cuid())
  label        String         // Human-readable name, e.g. "Dr. Aryan Sharma"
  username     String         @unique
  passwordHash String
  role         CredentialRole
  isActive     Boolean        @default(true)
  hospitalId   String
  createdBy    String         // adminId who generated this credential
  createdAt    DateTime       @default(now())
  lastLoginAt  DateTime?

  hospital            Hospital            @relation(fields: [hospitalId], references: [id])
  admin               Admin               @relation("CredentialCreatedBy", fields: [createdBy], references: [id])
  profileAccesses     ProfileAccess[]
  permissionRequests  PermissionRequest[]
  subscription        Subscription?
  aiUsages            AIUsage[]
  createdVisits       Visit[]             @relation("VisitCreatedBy")
  createdPatients     Patient[]           @relation("PatientCreatedBy")
  createdAppointments Appointment[]       @relation("AppointmentCreatedBy")
  auditLogs           AuditLog[]          @relation("AuditByCredential")

  @@index([hospitalId])
}

// A doctor's data profile — separate from their login credential.
// Holds all clinical data: visits, appointments.
// Multiple credentials can be granted access to the same DoctorProfile.
model DoctorProfile {
  id             String   @id @default(cuid())
  name           String
  specialty      String
  qualification  String?
  registration   String?
  phone          String?
  email          String?
  bio            String?
  hospitalId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hospital           Hospital            @relation(fields: [hospitalId], references: [id])
  profileAccesses    ProfileAccess[]
  visits             Visit[]
  appointments       Appointment[]
  permissionRequests PermissionRequest[]

  @@index([hospitalId])
}

// Junction: which credentials can access which DoctorProfile, and at what level.
// One row = one credential's access to one profile.
model ProfileAccess {
  id              String     @id @default(cuid())
  credentialId    String
  doctorProfileId String
  permission      Permission
  grantedAt       DateTime   @default(now())
  grantedBy       String     // adminId

  credential    Credential    @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  admin         Admin         @relation("AccessGrantedBy", fields: [grantedBy], references: [id])

  @@unique([credentialId, doctorProfileId])
  @@index([doctorProfileId])
}

// Request raised by a credential holder to upgrade VIEW → READ_WRITE on a profile.
// Admin approves or denies; the outcome is always audit-logged.
model PermissionRequest {
  id              String        @id @default(cuid())
  credentialId    String
  doctorProfileId String
  reason          String?       // Optional message from the requester
  status          RequestStatus @default(PENDING)
  requestedAt     DateTime      @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?       // adminId, populated on approve/deny

  credential    Credential    @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  admin         Admin?        @relation("RequestResolvedBy", fields: [resolvedBy], references: [id])

  @@index([credentialId])
  @@index([doctorProfileId])
  @@index([status])
}

// Patient record. Created by a receptionist credential on walk-in.
// Scoped to a hospital; never shared across hospitals.
model Patient {
  id                String   @id @default(cuid())
  name              String
  dob               String?  // ISO date string (YYYY-MM-DD); age is derived from this in the UI
  age               Int?
  gender            Gender?
  phone             String?
  email             String?
  bloodGroup        String?
  allergies         String?
  chronicConditions String?
  medicalHistory    String?
  insurance         String?
  address           String?
  emergencyContact  String?
  isReturning       Boolean  @default(false)
  aiSummary         String?   // Latest saved AI clinical summary (markdown text)
  aiSummaryModel    String?   // Model that produced the saved summary
  aiSummaryAt       DateTime? // When the summary was saved
  hospitalId        String
  registeredBy      String   // credentialId of the receptionist who registered them
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hospital     Hospital      @relation(fields: [hospitalId], references: [id])
  registrar    Credential    @relation("PatientCreatedBy", fields: [registeredBy], references: [id])
  visits       Visit[]
  appointments Appointment[]
  aiUsages     AIUsage[]

  @@index([hospitalId, createdAt])
  @@index([hospitalId, name])
}

// A clinical session record under a specific DoctorProfile.
// Initially created by a receptionist (chiefComplaint only);
// a credentialed doctor fills in examination, diagnosis, medications, notes, testReports.
model Visit {
  id              String   @id @default(cuid())
  patientId       String
  doctorProfileId String
  date            DateTime
  chiefComplaint  String
  weight          Float?   // Patient weight (kg) recorded at this visit
  examination     String?
  diagnosis       String?
  medications     String?
  prescription    String?
  testsPrescribed String?  // Tests the doctor ordered (free text / comma list)
  notes           String?
  followUpDate    DateTime?
  testReports     Json?    // Array of { name: string, url: string, type: string } (Azure Blob URLs)
  createdBy       String   // credentialId of whoever created this record
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id])
  creator       Credential    @relation("VisitCreatedBy", fields: [createdBy], references: [id])

  @@index([patientId, date])
  @@index([doctorProfileId, date])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorProfileId String
  hospitalId      String
  date            String            // YYYY-MM-DD
  time            String            // HH:MM
  reason          String
  notes           String?
  status          AppointmentStatus @default(scheduled)
  createdBy       String            // credentialId
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id])
  hospital      Hospital      @relation(fields: [hospitalId], references: [id])
  creator       Credential    @relation("AppointmentCreatedBy", fields: [createdBy], references: [id])

  @@index([hospitalId, date])
  @@index([doctorProfileId, date, time])
  @@index([patientId])
}

// Per-user AI subscription.
// FREE:    limited AI summaries per calendar month (enforced by counting AIUsage).
// PREMIUM: unlimited summaries, all model options available.
model Subscription {
  id                   String             @id @default(cuid())
  credentialId         String             @unique
  tier                  SubscriptionTier   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  gatewayCustomerId     String?            @unique // Razorpay customer id (optional)
  gatewaySubscriptionId String?            @unique // Razorpay subscription id
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
}

// One record per AI summary call.
// Used to enforce free-tier monthly limits and for usage analytics.
model AIUsage {
  id           String   @id @default(cuid())
  credentialId String
  patientId    String
  model        String   // e.g. "gpt-4o", "claude-3-5-sonnet-20241022", "gemini-1.5-pro"
  promptTokens Int
  outputTokens Int
  createdAt    DateTime @default(now())

  credential Credential @relation(fields: [credentialId], references: [id])
  patient    Patient    @relation(fields: [patientId], references: [id])

  @@index([credentialId, createdAt])
}

// Immutable audit trail — every action by any actor writes a record here.
// Either adminId OR credentialId is set, never both.
model AuditLog {
  id           String      @id @default(cuid())
  timestamp    DateTime    @default(now())
  action       AuditAction
  actorLabel   String      // Display name of the actor (for human-readable log UI)
  actorRole    String      // "ADMIN" | "DOCTOR" | "RECEPTIONIST"
  // Actor
  adminId      String?
  credentialId String?
  // Target — what was acted on
  targetType   String?     // "Patient" | "Visit" | "Credential" | "DoctorProfile" | etc.
  targetId     String?
  targetLabel  String?     // Human-readable name of the target
  details      String?     // Any extra context (JSON string or plain text)
  hospitalId   String
  ipAddress    String?

  hospital   Hospital    @relation(fields: [hospitalId], references: [id])
  admin      Admin?      @relation("AuditByAdmin", fields: [adminId], references: [id])
  credential Credential? @relation("AuditByCredential", fields: [credentialId], references: [id])

  @@index([hospitalId, timestamp])
  @@index([credentialId])
  @@index([action])
}

// Uploaded report file. Records which hospital owns each file so downloads can
// be permission-checked (a file is only ever accessible to its own hospital).
// The actual bytes live on disk (gzip-compressed) under `storedName`.
model Attachment {
  id         String   @id @default(cuid())
  hospitalId String                 // owning hospital — enforced on download
  visitId    String?                // optional link to the visit it belongs to
  storedName String                 // file on disk (uuid.ext), never exposed to clients
  fileName   String                 // original file name
  type       String                 // MIME type
  reportType String?                // category chosen in the UI (Prescription, …)
  uploadedBy String                 // credentialId of the uploader
  createdAt  DateTime @default(now())

  @@index([hospitalId])
}
