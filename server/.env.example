# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/healthvault?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated allowed CORS origins
ALLOWED_ORIGIN="http://localhost:5173"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Use a long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="12h"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Your Stripe Premium subscription price ID
STRIPE_PREMIUM_PRICE_ID="price_..."

# ─── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AIza..."

# ─── AI free-tier limit ───────────────────────────────────────────────────────
# Max AI summaries per calendar month on FREE tier
AI_FREE_MONTHLY_LIMIT=10

# ─── Rate limiting ────────────────────────────────────────────────────────────
# General API: requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Auth endpoints (stricter)
AUTH_RATE_LIMIT_MAX=10
# AI endpoints
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=3600000
