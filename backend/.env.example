# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (replace with your actual credentials)
DATABASE_URL="postgresql://postgres:password@localhost:5432/healthvault?schema=public"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300          # OTP valid for 5 minutes
OTP_MAX_ATTEMPTS=3              # Lock out after 3 wrong attempts

# Twilio credentials — sign up at https://twilio.com (free trial available)
# Leave blank to run in DEMO mode (OTP printed to server console instead of SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""          # Must be a Twilio number, e.g. +14155552671

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
