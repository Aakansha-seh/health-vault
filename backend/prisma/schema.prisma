// HealthVault — Prisma schema
// Database: PostgreSQL
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Clinic ───────────────────────────────────────────────────────────────────
model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String   @unique
  email     String   @unique
  password  String                        // bcrypt-hashed clinic admin password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors      Doctor[]
  patients     Patient[]
  appointments Appointment[]
}

// ─── Doctor ───────────────────────────────────────────────────────────────────
model Doctor {
  id              String   @id @default(cuid())
  name            String
  specialisation  String
  contact         String   @unique          // registered mobile — used as login
  email           String?  @unique
  password        String                    // bcrypt-hashed
  regNumber       String?
  clinicHours     String?
  yearsPractice   Int      @default(0)
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])

  visits       Visit[]
  appointments Appointment[]
  auditLogs    AuditLog[]
  otpSessions  OtpSession[]
}

// ─── Patient ──────────────────────────────────────────────────────────────────
model Patient {
  id                 String   @id @default(cuid())
  name               String
  age                Int
  gender             String
  bloodGroup         String?
  phone              String?
  allergies          String?
  chronicConditions  String?
  insurance          String?
  address            String?
  emergencyContact   String?
  isReturning        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id])

  visits       Visit[]
  appointments Appointment[]
}

// ─── Visit ────────────────────────────────────────────────────────────────────
model Visit {
  id               String   @id @default(cuid())
  date             DateTime
  chiefComplaint   String
  examination      String?
  diagnosis        String
  medications      String?   // newline-separated "Drug — dose" strings
  notes            String?
  createdAt        DateTime  @default(now())

  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])
}

// ─── Appointment ──────────────────────────────────────────────────────────────
model Appointment {
  id        String   @id @default(cuid())
  date      DateTime
  time      String   // "HH:MM"
  reason    String
  notes     String?
  status    String   @default("scheduled")  // scheduled | completed | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])

  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])

  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // LOGIN | ADD_PATIENT | ADD_VISIT | etc.
  detail    String?
  timestamp DateTime @default(now())

  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([timestamp])
}

// ─── OtpSession ───────────────────────────────────────────────────────────────
// Stores in-flight OTP verifications. Cleared after use or expiry.
model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  otp       String                         // bcrypt-hashed OTP
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  // If the session belongs to a doctor who is resetting their password
  doctorId  String?
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([phone])
}
